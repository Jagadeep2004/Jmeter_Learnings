            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="MagicProcess" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def addNumber = vars.get(&quot;addNumber&quot;)
def magic = vars.get(&quot;magic_g1&quot;)

if (!addNumber || !magic) {
    throw new IllegalStateException(
        &quot;Required values missing: addNumber=${addNumber}, magic=${magic}&quot;
    )
}

long result = addNumber.toLong() + magic.toLong()
vars.put(&quot;MagicNumber&quot;, result.toString())

log.info(&quot;MagicNumber calculation: ${addNumber} + ${magic} = ${result}&quot;)</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
