              <stringProp name="script">import java.io.FileOutputStream
import java.io.PrintStream

def username = vars.get(&quot;username&quot;)
def pass = vars.get(&quot;pass&quot;)

log.info(&quot;Username: &quot; + username)
log.info(&quot;Pass: &quot; + pass)

def f = new FileOutputStream(&quot;D:/Jmeter/petData.csv&quot;, true)
def p = new PrintStream(f)

p.print(username + &quot;,&quot; + pass + &quot;\r\n&quot;)

p.close()
f.close()</stringProp>
